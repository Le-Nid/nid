{
  "name": "gmail-manager-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Gmail Manager backend API — Fastify + TypeScript + Kysely",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0",
    "npm":  ">=10.0.0"
  },
  "scripts": {
    "dev":        "vite-node --watch src/index.ts",
    "build":      "vite build",
    "start":      "node dist/index.js",
    "typecheck":  "tsc --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest",
    "test:ui":    "vitest --ui",
    "lint":       "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors":       "^9.0.1",
    "@fastify/jwt":        "^8.0.1",
    "@fastify/multipart":  "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger":    "^8.15.0",
    "@fastify/swagger-ui": "^4.0.1",
    "archiver":            "^7.0.1",
    "bcrypt":              "^5.1.1",
    "bullmq":              "^5.7.0",
    "dotenv":              "^16.4.5",
    "fastify":             "^4.28.1",
    "googleapis":          "^144.0.0",
    "ioredis":             "^5.3.2",
    "kysely":              "^0.27.4",
    "mailparser":          "^3.7.1",
    "nodemailer":          "^6.9.13",
    "pg":                  "^8.11.5",
    "pino":                "^9.1.0",
    "pino-pretty":         "^11.0.0",
    "zod":                 "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver":     "^6.0.2",
    "@types/bcrypt":       "^5.0.2",
    "@types/mailparser":   "^3.4.4",
    "@types/node":         "^24.0.0",
    "@types/pg":           "^8.11.6",
    "@vitest/coverage-v8": "^2.0.0",
    "@vitest/ui":          "^2.0.0",
    "eslint":              "^9.5.0",
    "typescript":          "^5.5.0",
    "vite":                "^5.3.1",
    "vite-node":           "^2.0.0",
    "vitest":              "^2.0.0"
  }
}
