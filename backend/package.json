{
  "name": "gmail-manager-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Gmail Manager backend API — Fastify + TypeScript + Kysely",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0",
    "npm":  ">=10.0.0"
  },
  "scripts": {
    "dev":        "vite-node --watch src/index.ts",
    "build":      "vite build",
    "start":      "node dist/index.js",
    "typecheck":  "tsc --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest",
    "test:ui":    "vitest --ui",
    "lint":       "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors":       "^11.2.0",
    "@fastify/jwt":        "^10.0.0",
    "@fastify/multipart":  "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger":    "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "archiver":            "^7.0.1",
    "bcrypt":              "^6.0.0",
    "bullmq":              "^5.7.0",
    "dotenv":              "^16.4.5",
    "fastify":             "^5.8.4",
    "googleapis":          "^144.0.0",
    "ioredis":             "^5.3.2",
    "kysely":              "^0.28.14",
    "mailparser":          "^3.9.6",
    "nodemailer":          "^8.0.4",
    "otplib":              "^12.0.1",
    "pg":                  "^8.11.5",
    "pino":                "^9.1.0",
    "pino-pretty":         "^11.0.0",
    "qrcode":              "^1.5.4",
    "zod":                 "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver":     "^6.0.2",
    "@types/bcrypt":       "^5.0.2",
    "@types/mailparser":   "^3.4.4",
    "@types/node":         "^24.0.0",
    "@types/pg":           "^8.11.6",
    "@types/qrcode":       "^1.5.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui":          "^4.1.2",
    "eslint":              "^9.15.0",
    "typescript":          "^5.7.0",
    "vite":                "^8.0.3",
    "vite-node":           "^6.0.0",
    "vitest":              "^4.1.2"
  }
}
