{
  "name": "nid-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Nid backend API — Fastify + TypeScript + Kysely",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' vite-node --watch src/index.ts",
    "build": "vite build",
    "build:mcp": "vite build --config vite.config.mcp.ts",
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first' node dist/index.js",
    "start:mcp": "NODE_OPTIONS='--dns-result-order=ipv4first' node dist/mcp-server.js",
    "typecheck": "tsc --noEmit",
    "check": "npm ci && npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/lib-storage": "^3.1024.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^7.0.1",
    "arctic": "^3.7.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "dotenv": "^17.4.0",
    "fastify": "^5.8.4",
    "googleapis": "^171.4.0",
    "imapflow": "^1.2.18",
    "ioredis": "^5.3.2",
    "kysely": "^0.28.15",
    "mailparser": "^3.9.6",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/imapflow": "^1.0.23",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
