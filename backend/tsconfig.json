{
  "compilerOptions": {
    "target":                          "ES2023",
    "module":                          "CommonJS",
    "lib":                             ["ES2023"],
    "outDir":                          "./dist",
    "rootDir":                         "./src",
    "strict":                          true,
    "esModuleInterop":                 true,
    "skipLibCheck":                    true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":               true,
    "declaration":                     true,
    "declarationMap":                  true,
    "sourceMap":                       true,
    "types":                           ["node", "vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
