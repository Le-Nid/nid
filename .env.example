# ─── App ──────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_generate_with_openssl_rand_hex_64

# ─── Google OAuth2 ────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/gmail/callback
GOOGLE_SSO_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=gmailmanager
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=gmailmanager

# ─── Archive ──────────────────────────────────────────
# Path inside the container, mapped to your NAS via volumes
ARCHIVE_PATH=/archives
