# ─── App ──────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_generate_with_openssl_rand_hex_64

# ─── Google OAuth2 ────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/gmail/callback
GOOGLE_SSO_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ─── Social OAuth (optionnel) ─────────────────────────
# Chaque provider est activé dès que CLIENT_ID + CLIENT_SECRET sont définis.
# Les providers non configurés ne sont pas affichés sur la page de connexion.

# Microsoft — https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Discord — https://discord.com/developers/applications
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Facebook (Meta) — https://developers.facebook.com/apps
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# LinkedIn — https://www.linkedin.com/developers/apps
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Keycloak — URL du realm + credentials
# KEYCLOAK_REALM_URL=https://auth.example.com/realms/myrealm
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=

# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=gmailmanager
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=gmailmanager

# ─── Archive ──────────────────────────────────────────
# Path inside the container, mapped to your NAS via volumes
ARCHIVE_PATH=/archives

# ─── Inscription ─────────────────────────────────────
# Mettre à false pour fermer les inscriptions
ALLOW_REGISTRATION=true

# ─── Admin ────────────────────────────────────────
# Le premier utilisateur avec cet email devient admin
ADMIN_EMAIL=
